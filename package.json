{
  "name": "nocodeofconduct.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bunx --bun astro dev",
    "build": "bunx --bun astro build",
    "preview": "bunx --bun astro preview",
    "check": "bunx --bun astro check && tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "bun run fmt:biome",
    "fmt:check": "bun run fmt:check:biome",
    "fmt:biome": "biome format --write .",
    "fmt:check:biome": "biome format .",
    "postbuild": "bun ./scripts/verify-dist.ts",
    "verify:dist": "bun ./scripts/verify-dist.ts",
    "diag:dist": "bun ./scripts/diagnose-dist.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:ci": "CI=1 bun test --reporter=junit --reporter-outfile=./reports/bun-test.xml",
    "audit": "bun audit",
    "deps:outdated": "bun outdated",
    "quality": "bun ./scripts/quality.ts",
    "quality:ci": "bun ./scripts/quality.ts --ci"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.1",
    "@primer/css": "^22.1.1",
    "@primer/octicons-react": "^19.23.1",
    "@primer/react": "^38.17.0",
    "astro": "^6.0.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2"
  }
}
