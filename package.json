{
  "name": "nocodeofconduct.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "bun run fmt:biome && bun run fmt:astro",
    "fmt:check": "bun run fmt:check:biome && bun run fmt:check:astro",
    "fmt:biome": "biome format --write .",
    "fmt:check:biome": "biome format .",
    "fmt:astro": "prettier --write \"src/**/*.astro\"",
    "fmt:check:astro": "prettier --check \"src/**/*.astro\"",
    "postbuild": "bun ./scripts/verify-dist.ts",
    "verify:dist": "bun ./scripts/verify-dist.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.1",
    "@primer/octicons-react": "^19.23.1",
    "@primer/react-brand": "^0.65.1",
    "astro": "^6.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "^5.9.3"
  }
}
